; Template for consumer projects installing @amerilux packages from GitHub Packages.
; npm expands ${...} from environment variables. Load your token into the shell
; before running `npm install`, or expose it from a CI secret.
;
; The token needs the `read:packages` scope (classic Personal Access Token),
; or use the `GITHUB_TOKEN` provided automatically inside GitHub Actions.

@amerilux:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
always-auth=true
