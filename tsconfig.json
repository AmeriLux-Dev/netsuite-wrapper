{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "N/*": ["./node_modules/@hitc/netsuite-types/N/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/generated/**/*"]
}